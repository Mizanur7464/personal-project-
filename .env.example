# Copy to .env and replace YOUR_* placeholders.
# cp .env.example .env   (Linux/Mac)
# copy .env.example .env (Windows)

# --- Required ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
ADMIN_TELEGRAM_ID=YOUR_TELEGRAM_USER_ID

# --- Payment provider: nowpayments | cryptomus ---
PAYMENT_PROVIDER=nowpayments

# --- Subscription & pricing ---
SUBSCRIPTION_DAYS=30
PLAN_PRO_USD=15.00
PLAN_ELITE_USD=19.99
RENEWAL_REMINDER_DAYS=3
RENEWAL_REMINDER_THRESHOLDS=7,3,1
SUBSCRIPTION_CHECK_HOURS=6
DB_BACKUP_HOURS=24

# --- Referral rewards (bonus days) ---
REFERRAL_REFEREE_BONUS_DAYS=3
REFERRAL_REFERRER_BONUS_DAYS=3
REFERRAL_REFEREE_TIER=pro

# --- Weekly auto summary (UTC): 0=Monday ---
WEEKLY_SUMMARY_DAY=0
WEEKLY_SUMMARY_HOUR=9

# --- Alert & watchlist limits ---
ALERT_LIMIT_FREE=0
ALERT_LIMIT_PRO=10
ALERT_LIMIT_ELITE=50
WATCHLIST_LIMIT_PRO=10
WATCHLIST_LIMIT_ELITE=25
ALERTS_POLL_SECONDS=20

# --- Rate limit (per user per minute) ---
RATE_LIMIT_CALLS=15
RATE_LIMIT_WINDOW_SEC=60

# --- NOWPayments ---
NOWPAYMENTS_API_KEY=YOUR_NOWPAYMENTS_API_KEY
NOWPAYMENTS_IPN_SECRET=YOUR_NOWPAYMENTS_IPN_SECRET
NOWPAYMENTS_IPN_CALLBACK_URL=https://YOUR-DOMAIN.com/webhook/nowpayments
NOWPAYMENTS_SUCCESS_URL=https://t.me/YOUR_BOT_USERNAME
NOWPAYMENTS_CANCEL_URL=https://t.me/YOUR_BOT_USERNAME
NOWPAYMENTS_PAY_CURRENCY=usdttrc20
NOWPAYMENTS_MODE=address

# --- Webhook server ---
WEBHOOK_PORT=8080

# --- Auto broadcast to channels (no manual posting) ---
AUTO_BROADCAST_ENABLED=true
FREE_BROADCAST_HOURS=8
PRO_BROADCAST_HOURS=4
ELITE_BROADCAST_HOURS=4
SIGNAL_COINS=BTC,ETH,SOL,BNB,XRP
SIGNAL_INTERVAL=1h
VOLATILITY_THRESHOLD=5.0

# --- Binance (use api1 if api.binance.com is blocked) ---
BINANCE_API_BASE_URL=https://api1.binance.com
BINANCE_MAX_PARALLEL=3
MARKET_CACHE_TTL_SEC=300

# --- Channels (bot = admin: post messages + invite + ban) ---
FREE_CHANNEL_ID=-1001234567890
PRO_CHANNEL_ID=-1001234567891
ELITE_CHANNEL_ID=-1001234567892

# --- OpenAI (optional) ---
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4.1-mini

# --- Cryptomus (only if PAYMENT_PROVIDER=cryptomus) ---
#CRYPTOMUS_MERCHANT_UUID=YOUR_CRYPTOMUS_MERCHANT_UUID
#CRYPTOMUS_API_KEY=YOUR_CRYPTOMUS_API_KEY

# --- Logging ---
LOG_LEVEL=INFO
